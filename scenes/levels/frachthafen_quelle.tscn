; Die QUELLE der Frachthafen-Karte — duenn, mit dem Layout-Skript am Knoten
; "Welt". Hier wird nichts von Hand gebaut.
;
; tools/bake_frachthafen.gd liest diese Datei, laesst das Skript die Welt
; erzeugen und schreibt das Ergebnis nach raid_frachthafen.tscn. Erst dort
; stehen die 2400 Knoten, und erst dort laesst sich im Editor etwas anfassen.
;
; WARUM GETRENNT: Wuerde beides in derselben Datei liegen, ueberschriebe das
; Backen seine eigene Vorlage — und danach koennte man die Karte nie wieder
; aus dem Layout neu erzeugen. Genau das ist einmal passiert.
[gd_scene load_steps=10 format=3]

[ext_resource type="PackedScene" path="res://scenes/player/player.tscn" id="1_player"]
[ext_resource type="Script" path="res://scripts/levels/raid_level.gd" id="2_raid_level"]
[ext_resource type="Script" path="res://scripts/raid/raid_manager.gd" id="3_raid_manager"]
[ext_resource type="Script" path="res://scripts/levels/frachthafen_layout.gd" id="4_layout"]
[ext_resource type="PackedScene" path="res://scenes/ui/loot_window.tscn" id="5_loot_window"]
[ext_resource type="PackedScene" path="res://scenes/ui/character_window.tscn" id="6_character_window"]

[sub_resource type="ProceduralSkyMaterial" id="Sky_hafen"]
sky_top_color = Color(0.4, 0.46, 0.56, 1)
sky_horizon_color = Color(0.7, 0.74, 0.79, 1)
ground_bottom_color = Color(0.58, 0.62, 0.68, 1)
ground_horizon_color = Color(0.7, 0.74, 0.79, 1)

[sub_resource type="Sky" id="Sky_main"]
sky_material = SubResource("Sky_hafen")

[sub_resource type="Environment" id="Env_hafen"]
background_mode = 2
sky = SubResource("Sky_main")
ambient_light_source = 3
ambient_light_color = Color(0.7, 0.75, 0.82, 1)
ambient_light_sky_contribution = 0.9
ambient_light_energy = 1.0
fog_enabled = true
fog_light_color = Color(0.76, 0.79, 0.84, 1)
fog_density = 0.006
fog_sky_affect = 0.4

[node name="RaidFrachthafen" type="Node3D"]
script = ExtResource("2_raid_level")

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Env_hafen")

[node name="Sonne" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.82, -0.31, 0.48, 0, 0.84, 0.54, -0.57, -0.44, 0.69, 0, 40, 0)
light_color = Color(1, 0.96, 0.9, 1)
light_energy = 0.8
shadow_enabled = true

[node name="RaidManager" type="Node" parent="."]
script = ExtResource("3_raid_manager")

[node name="Welt" type="Node3D" parent="."]
script = ExtResource("4_layout")

[node name="Player" parent="." instance=ExtResource("1_player")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -60, 0.2, 100)

[node name="HUD" type="CanvasLayer" parent="."]

[node name="InfoPanel" type="PanelContainer" parent="HUD"]
offset_left = 16.0
offset_top = 16.0
offset_right = 380.0
offset_bottom = 320.0

[node name="InfoLabel" type="Label" parent="HUD/InfoPanel"]
text = "..."

[node name="LootWindow" parent="HUD" instance=ExtResource("5_loot_window")]

[node name="CharacterWindow" parent="HUD" instance=ExtResource("6_character_window")]

[node name="PromptLabel" type="Label" parent="HUD"]
